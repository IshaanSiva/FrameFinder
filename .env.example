# ── Supabase (required) ───────────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...        # anon/public key — safe to expose
SUPABASE_SERVICE_ROLE_KEY=eyJ...            # server-only, never expose to client

# ── Gemini (required) ─────────────────────────────────────────────────────────
# From: Google AI Studio → Get API Key
GEMINI_API_KEY=AIza...

# ── Stripe (optional — app works without these) ───────────────────────────────
# From: Stripe Dashboard → Developers → API Keys
# Omitting these disables the upgrade/checkout flow; all other features still work.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# From: Stripe Dashboard → Products → Student Pro → Price ID
STRIPE_STUDENT_PRO_PRICE_ID=price_test_...

# From: Stripe Dashboard → Developers → Webhooks → Signing Secret
# Or: `stripe listen --forward-to localhost:3000/api/stripe/webhook` for local dev
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App URL (required) ────────────────────────────────────────────────────────
# Used for Stripe checkout redirect URLs and Supabase auth email redirects.
# Local dev: http://localhost:3000
# Production: https://your-domain.com  (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
